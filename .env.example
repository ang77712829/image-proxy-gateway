# 图片网关配置文件示例
# 复制本文件为 .env，然后按需填写。默认已经内置三个图片渠道：硅基流动、魔搭、Pollinations。
# 新手建议：优先填写 SILICONFLOW_API_KEY；再填写 MODELSCOPE_API_KEY；POLLINATIONS_API_KEY 可以先留空。

# ── 默认图片渠道一：硅基流动 SiliconFlow ──
# 注册入口：https://cloud.siliconflow.cn
# 获取方式：注册并登录控制台 → 打开 密钥页面 → 创建密钥 → 复制 sk- 开头的密钥
# 用途：启用 kolors / siliconflow 别名，对应 Kwai-Kolors/Kolors 通道
SILICONFLOW_API_KEY=

# ── 默认图片渠道二：魔搭 ModelScope ──
# 注册入口：https://modelscope.cn
# 获取方式：注册并登录 → 个人中心 / 访问令牌 / 访问令牌 → 创建并复制令牌
# 用途：启用 qwen、flux、z-image、z-turbo 四个别名
MODELSCOPE_API_KEY=

# ── 默认图片渠道三：Pollinations ──
# 入口：https://pollinations.ai 或 https://enter.pollinations.ai
# 不填写时：网关会尝试旧公共图片接口做兜底
# 填写时：优先使用新版 兼容 OpenAI 图片接口
POLLINATIONS_API_KEY=


# ── 可选渠道：Agnes AI 图片/视频 ──
# 文档入口：https://agnes-ai.com/doc
# 只有显式指定 agnes-2.1 / agnes-2.0 / agnes-image 或调用 /v1/videos 时才会使用
# 注意：Agnes 是否免费、额度多少、哪些模型可用，以 Agnes 后台和官方文档为准
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MAX_POLL_TIME=600
AGNES_VIDEO_POLL_INTERVAL=5

# ── 可选付费图片渠道：兼容 OpenAI 图片接口 ──
# 只有显式指定 gpt-image-2 或 openai-image 时才会调用，不会进入默认免费降级链
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2

# ── 网关访问保护 ──
# 局域网多人使用或公网部署时必须设置；本机测试可以留空
GATEWAY_API_KEY=

# ── 服务监听配置 ──
# PROXY_HOST=0.0.0.0 表示允许局域网访问；只想本机访问可改成 127.0.0.1
PROXY_HOST=0.0.0.0
PROXY_PORT=9890

# ── 返回图片地址配置 ──
# 如果 Agent / New-API 和网关不在同一台机器，请改成网关机器的局域网或公网地址
# 示例：http://192.168.1.10:9890
PUBLIC_BASE_URL=http://localhost:9890

# ── 本地状态和图片缓存目录 ──
# IMAGE_PROXY_STATE_DIR 是默认状态目录；QUOTA_FILE 和 OUTPUT_DIR 留空时会自动放在该目录下
# 本机 / NAS 直接运行建议使用 ~/.image-proxy，Docker Compose 会通过挂载卷覆盖为 /data
IMAGE_PROXY_STATE_DIR=~/.image-proxy
# QUOTA_FILE=
# OUTPUT_DIR=

# ── 魔搭本地保护计数 ──
# 我们实测图片生成通道约为所有图片模型共享 50 张/天，所以默认按 50 做本地保护
# 真实额度以魔搭平台返回为准，本地计数只是防止重复撞限额
MODELSCOPE_DAILY_LIMIT=50

# ── Pollinations 默认模型 ──
POLLINATIONS_MODEL=zimage

# ── 网络超时和轮询配置 ──
HTTP_TIMEOUT=60
MAX_POLL_TIME=120
POLL_INTERVAL=3

# ── 魔搭异步任务头配置 ──
# 提交任务和轮询任务的类型值不同，不要随意合并
MODELSCOPE_SUBMIT_TASK_TYPE=text-to-image-generation
MODELSCOPE_POLL_TASK_TYPE=image_generation

# ── 预留渠道：即梦等其他图片平台 ──
# 当前只是预留变量，后续接入真实接口时再启用
# JIMENG_API_KEY=
# JIMENG_BASE_URL=
