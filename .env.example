# AngeMedia Gateway environment example.
# Fill at least one provider key before using generation in production.

# Built-in image/video providers
SILICONFLOW_API_KEY=
MODELSCOPE_API_KEY=
POLLINATIONS_API_KEY=
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MAX_POLL_TIME=600
AGNES_VIDEO_POLL_INTERVAL=5

# OpenAI-compatible image provider
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2

# Ange assistant, OpenAI-compatible chat completions (WIP — not part of v0.2.0 stable)
ANGE_ASSISTANT_ENABLED=false
ANGE_LLM_API_KEY=
ANGE_LLM_BASE_URL=https://api.openai.com/v1
ANGE_LLM_MODEL=gpt-4o-mini
ANGE_LLM_TEMPERATURE=0.6
ANGE_LLM_TIMEOUT=60
ANGE_ASSISTANT_ALLOW_PAID=false
ANGE_ASSISTANT_ALLOW_AGNES=false
ANGE_ASSISTANT_CONFIRM_PLAN=true

# Server
PROXY_HOST=0.0.0.0
PROXY_PORT=9890
PUBLIC_BASE_URL=http://localhost:9890
IMAGE_PROXY_STATE_DIR=/data
OUTPUT_DIR=/data/generated
UPLOAD_DIR=/data/uploads
ANGEMEDIA_DB_FILE=/data/angemedia.db

# Security
GATEWAY_API_KEY=
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-this-password
ADMIN_COOKIE_SECURE=false

# Runtime limits
AUTO_DOWNLOAD_GENERATED=true
LOCALIZE_STRICT=false
MEDIA_DOWNLOAD_MAX_BYTES=314572800
UPLOAD_MAX_FILES=10
HTTP_TIMEOUT=60
MAX_POLL_TIME=120
POLL_INTERVAL=3

# ModelScope and Pollinations tuning
MODELSCOPE_DAILY_LIMIT=50
MODELSCOPE_SUBMIT_TASK_TYPE=text-to-image-generation
MODELSCOPE_POLL_TASK_TYPE=image_generation
POLLINATIONS_MODEL=zimage

# Built-in provider switches
BUILTIN_PROVIDER_SILICONFLOW_ENABLED=true
BUILTIN_PROVIDER_MODELSCOPE_ENABLED=true
# Experimental, not in default fallback chain
BUILTIN_PROVIDER_POLLINATIONS_ENABLED=false
BUILTIN_PROVIDER_OPENAI_IMAGE_ENABLED=true
BUILTIN_PROVIDER_AGNES_IMAGE_ENABLED=true
BUILTIN_PROVIDER_AGNES_VIDEO_ENABLED=true
